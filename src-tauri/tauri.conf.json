{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CircuitClaude",
  "version": "0.2.3",
  "identifier": "com.circuit.circuitclaude",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/copy-cuda-dlls.cjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CircuitClaude",
        "width": 1200,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "sidecar/claude-bridge.mjs": "sidecar/claude-bridge.mjs",
      "cuda-runtime/cublas64_13.dll": "cublas64_13.dll",
      "cuda-runtime/cublasLt64_13.dll": "cublasLt64_13.dll",
      "cuda-runtime/cudart64_13.dll": "cudart64_13.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBCNzZBQTAwRkQ5OTBGRDAKUldUUUQ1bjlBS3AyQ3dGL3VPbUJFMW5SNFdlVS9nMlgrMU1oRC9KcEJVb05jbXRiRlpNZEMxU08K",
      "endpoints": [
        "https://github.com/CircuitLord/CircuitClaude/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
